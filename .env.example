# ==========================================
# BuildTrack - Environment Variables
# ==========================================

# 🚨 ملاحظة هامة:
# هذا الملف للإرشادات فقط - لا تضع بيانات حقيقية هنا!
# أنشئ ملف .env.local الخاص بك للبيانات الحقيقية.

# ==========================================
# Database Configuration - Supabase
# ==========================================

# مثال لـ Supabase PostgreSQL (استخدم هذا في Vercel):
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres"

# Supabase Project Info (اختياري - للتطوير المحلي)
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR_ANON_KEY_HERE"

# ==========================================
# مثال للإنتاج مع Supabase:
# ==========================================
# DATABASE_URL="postgresql://postgres:lL5OvpM9vSzCKYGW@db.fziikvgrnwkqfzfnebjw.supabase.co:5432/postgres"
# NEXT_PUBLIC_SUPABASE_URL="https://fziikvgrnwkqfzfnebjw.supabase.co"
# NEXT_PUBLIC_SUPABASE_ANON_KEY="sb_publishable_Ajim28MARlzKgCDULfqqtA_NILNke6C"

# ==========================================
# خيارات أخرى لقواعد البيانات:
# ==========================================

# Vercel Postgres:
# DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# Neon:
# DATABASE_URL="postgresql://user:password@host/database?sslmode=require"

# PlanetScale (MySQL):
# DATABASE_URL="mysql://user:password@host:3306/database"

# ==========================================
# للتطوير المحلي فقط (SQLite):
# ==========================================
# DATABASE_URL="file:./dev.db"
# ==========================================

# ==========================================
# NextAuth Configuration (اختياري)
# ==========================================
# NEXTAUTH_URL="https://your-app.vercel.app"
# NEXTAUTH_SECRET="generate-a-random-secret-key"

# ==========================================
# Environment
# ==========================================
NODE_ENV="production"
