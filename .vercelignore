# Ignore local database files
*.db
*.db-shm
*.db-wal
db/

# Ignore node_modules (but Vercel handles this automatically)
node_modules/

# Ignore .git (Vercel handles this automatically)
.git/

# Ignore .env files (but we need .env.example)
.env
.env.local
.env.*.local

# Ignore logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Ignore IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# Ignore OS files
.DS_Store
Thumbs.db

# Ignore test files
__tests__/
*.test.js
*.test.ts
*.spec.js
*.spec.ts

# Ignore build artifacts (Next.js handles this)
.next/
out/
build/
dist/
