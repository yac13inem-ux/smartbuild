# ==========================================
# BuildTrack - Environment Variables
# ==========================================

# 🚨 IMPORTANTE: SQLite لا يعمل على Vercel!
# يجب استخدام قاعدة بيانات سحابية مثل PostgreSQL أو MySQL

# ==========================================
# Database Configuration
# ==========================================

# ⚠️ للإنتاج على Vercel - استخدم PostgreSQL:
# الخيارات:
# 1. Vercel Postgres (مجاني للبداية)
# 2. Supabase (مجاني)
# 3. Neon (مجاني)
# 4. PlanetScale (مجاني - MySQL)

# قالب Vercel Postgres:
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# قالب Supabase:
# DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# قالب Neon:
# DATABASE_URL="postgresql://[user]:[password]@[host]/[database]?sslmode=require"

# ==========================================
# للتطوير المحلي فقط (SQLite):
# ==========================================
# DATABASE_URL="file:./dev.db"
# ==========================================

# ==========================================
# NextAuth Configuration (اختياري)
# ==========================================
# NEXTAUTH_URL="https://your-app.vercel.app"
# NEXTAUTH_SECRET="generate-a-random-secret-key"

# ==========================================
# Environment
# ==========================================
NODE_ENV="production"
